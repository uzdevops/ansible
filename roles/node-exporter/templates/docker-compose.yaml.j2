# Ansible managed
services:
  {{ node_exporter_service_name }}:
    image: {{ node_exporter_image }}
    network_mode: host
    pid: host
    restart: always
    volumes:
{% for v in node_exporter_volumes %}
      - {{ v }}
{% endfor %}
    command:
{% for c in node_exporter_command %}
      - {{ c }}
{% endfor %}
    deploy:
      resources:
        limits:
          memory: {{ node_exporter_memory_limit }}
        reservations:
          memory: {{ node_exporter_memory_reservation }}
